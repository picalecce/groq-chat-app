{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "app/api/chat/route.ts": {
      "maxDuration": 90
    },
    "app/api/extract/route.ts": {
      "maxDuration": 30
    },
    "app/api/memory/route.ts": {
      "maxDuration": 15
    },
    "app/api/cron/refresh-norme/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/refresh-norme",
      "schedule": "0 3 * * 0"
    }
  ]
}
